# Gaggle 服务器配置
# 复制此文件为 .env 并填入实际值: cp .env.example .env

# 服务器监听地址 (0.0.0.0 监听所有接口)
GAGGLE_HOST=0.0.0.0

# 服务器监听端口
GAGGLE_PORT=8080

# SQLite 数据库路径 (相对于 WorkingDirectory)
GAGGLE_DATABASE_PATH=gaggle.db

# 服务器间认证密钥 (可选，用于服务间 API 调用)
# 生产环境建议设置
GAGGLE_SERVER_API_KEY=

# Solana 区块链配置
SOLANA_RPC_URL=https://api.devnet.solana.com

# 日志级别 (RUST_LOG 格式)
# 开发: debug,gaggle=trace
# 生产: info,gaggle=debug
RUST_LOG=info,gaggle=debug
